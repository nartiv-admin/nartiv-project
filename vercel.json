{
    "rewrites": [
          { "source": "/api/claude", "destination": "/api/claude" },
          { "source": "/api/keep-alive", "destination": "/api/keep-alive" },
          { "source": "/(.*)", "destination": "/public/index.html" }
    ],
    "crons": [
          {
                  "path": "/api/keep-alive",
                  "schedule": "0 9 */3 * *"
          }
    ]
}
